# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Windows specific files
*.bat text eol=crlf
*.cmd text eol=crlf

# Java / Maven
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Frontend
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.json text eol=lf

# Binary files - nie dotykaj końców linii
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary
*.pdf binary
